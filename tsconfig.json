{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "baseUrl": ".",
    "paths": {
      "@alvas/api/*": ["apps/api/src/*"],
      "@alvas/web/*": ["apps/web/src/*"],
      "@alvas/shared-types": ["packages/shared-types/src/index.ts"],
      "@alvas/shared-types/*": ["packages/shared-types/src/*"],
      "@alvas/shared-utils": ["packages/shared-utils/src/index.ts"],
      "@alvas/shared-utils/*": ["packages/shared-utils/src/*"]
    }
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist", "out", ".wrangler", "coverage"]
}
